# Core app
DEBUG="True"
SITE_NAME="NextGen Bank"
SECRET_KEY="<GENERATE_SECRET_KEY>"
ADMIN_URL="admin/"
DOMAIN="localhost:8080"
COOKIE_SECURE="False"
SIGNING_KEY="<GENERATE_OPENSSL_BASE64_48>"

# Email
EMAIL_HOST="mailpit"
EMAIL_PORT="1025"
DEFAULT_FROM_EMAIL="NextGen Bank <noreply@nextgenbank.com>"

# Database
POSTGRES_HOST="postgres"
POSTGRES_PORT="5432"
POSTGRES_DB="banker"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="<SET_DB_PASSWORD>"

# Bank config
BANK_NAME="NextGen Bank"
BANK_CODE="211"
BANK_BRANCH_CODE="700"
CURRENCY_CODE_KES="01"
CURRENCY_CODE_USD="02"
CURRENCY_CODE_GBP="03"
BANK_CARD_PREFIX="4132"
BANK_CARD_CODE="1300"
# Generate: openssl rand -base64 32
CVV_SECRET_KEY="<GENERATE_OPENSSL_BASE64_32>"
ADMIN_EMAIL="admin@nextgenbank.com"
LARGE_TRANSACTION_THRESHOLD="1000000.00"
FREQUENT_TRANSACTION_THRESHOLD="10"
TIME_WINDOW_HOURS="24"

# Celery
CELERY_FLOWER_USER="admin"
CELERY_FLOWER_PASSWORD="<SET_FLOWER_PASSWORD>"
CELERY_BROKER_URL="amqp://rabbitmq"
CELERY_RESULT_BACKEND="redis://redis:6379/0"

# Cloudinary
# Get from: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME="<FROM_CLOUDINARY_DASHBOARD>"
CLOUDINARY_API_KEY="<FROM_CLOUDINARY_DASHBOARD>"
CLOUDINARY_API_SECRET="<FROM_CLOUDINARY_DASHBOARD>"

# Seed superuser
SEED_SUPERUSER_EMAIL="admin@django.com"
SEED_SUPERUSER_PASSWORD="<SET_STRONG_PASSWORD>"
SEED_SUPERUSER_FIRST_NAME="System"
SEED_SUPERUSER_MIDDLE_NAME=""
SEED_SUPERUSER_LAST_NAME="Admin"
SEED_SUPERUSER_SECURITY_QUESTION="maiden_name"
SEED_SUPERUSER_SECURITY_ANSWER="<SET_PRIVATE_ANSWER>"
SEED_SUPERUSER_ID_NO="<SET_PRIVATE_ID_NO>"
SEED_SUPERUSER_ROLE="branch_manager"